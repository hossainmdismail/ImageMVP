AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
AI_API_KEY=your_ai_api_key_here
AI_TEXT_MODEL=gemini-2.5-flash
AI_IMAGE_MODEL=gemini-3.1-flash-image-preview
AI_RESPONSES_MODEL=gemini-2.5-flash
AI_API_URL=
AI_OPENAI_USE_RESPONSES_IDENTITY=false
AI_MAX_REFERENCE_IMAGES=3
AI_IMAGE_SIZE=1K
AI_IMAGE_ASPECT_RATIO=4:5
AI_IMAGE_QUALITY=high
AI_INPUT_FIDELITY=high
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=yamaha_ai
DB_CONNECTION_LIMIT=50
OTP_SECRET=change_me_local
BULKSMSBD_API_KEY=your_bulksmsbd_api_key_here
BULKSMSBD_SENDER_ID=your_sender_id_here
REPLICATE_MODEL=
STABILITY_API_KEY=
CUSTOM_AI_TEXT_PATH=/text
CUSTOM_AI_IMAGE_PATH=/image
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_SESSION_SECRET=long_random_secret

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your_account/your_queue_name
